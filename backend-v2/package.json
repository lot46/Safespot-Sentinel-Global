    "@typescript-eslint/parser": "^6.16.0",
    "@vitest/ui": "^1.1.1",
    "audit-ci": "^6.6.1",
    "better-npm-audit": "^3.7.3",
    "eslint": "^8.56.0",
    "jest": "^30.1.3",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.4",
    "tsc-alias": "^1.8.8",
    "tsx": "^4.6.2",
