    "@fastify/jwt": "^7.2.4",
    "@fastify/multipart": "^8.0.0",
    "@fastify/oauth2": "^8.1.2",
    "@fastify/rate-limit": "^9.0.1",
    "@fastify/redis": "^6.1.1",
    "@fastify/sensible": "^5.5.0",
    "@fastify/static": "^6.12.0",
    "@fastify/swagger": "^8.12.2",
    "@fastify/swagger-ui": "^2.1.0",
    "@fastify/websocket": "^7.2.0",
    "@prisma/client": "^5.7.1",
    "aws-sdk": "^2.1522.0",
