    "nanoid": "^5.0.4",
    "nodemailer": "^6.9.8",
    "otplib": "^12.0.1",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "prisma": "^5.7.1",
    "qrcode": "^1.5.3",
