{
  "name": "safespot-sentinel-backend-v2",
  "version": "2.0.0",
  "description": "SafeSpot Sentinel Global - Enterprise Backend with PostgreSQL, PostGIS, WebSocket, OAuth2, 2FA, RBAC",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "type-check": "tsc --noEmit",
    "test": "jest --runInBand",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:reset": "prisma migrate reset -f",
    "generate": "prisma generate",
    "seed": "tsx prisma/seeds/seed.ts",
