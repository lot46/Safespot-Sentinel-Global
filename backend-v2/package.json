{
  "name": "safespot-sentinel-backend-v2",
  "private": true,
  "type": "module",
  "version": "2.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "type-check": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:moderation": "jest __tests__/moderation.service.test.ts --runInBand",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:reset": "prisma migrate reset -f",
    "generate": "prisma generate",
    "seed": "tsx prisma/seeds/seed.ts",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/cookie": "^10",
    "@fastify/cors": "^10",
    "@fastify/helmet": "^13",
    "@fastify/jwt": "^9",
    "@fastify/multipart": "^8",
    "@fastify/oauth2": "^8",
    "@fastify/rate-limit": "^10",
    "@fastify/redis": "^7",
    "@fastify/sensible": "^6",
    "@fastify/swagger": "^9",
    "@fastify/swagger-ui": "^5",
    "@fastify/websocket": "^10",
    "fastify": "^5",
    "pino": "^9.11.0",
    "pino-pretty": "^13.1.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.2",
    "jest": "^30.1.3",
    "ts-jest": "^29.4.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
