// SafeSpot Sentinel Global V2 - Prisma Schema (updated for encryption-at-rest)
// PostgreSQL 15 + PostGIS (geometry stored as Unsupported type)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum Role {
  USER
  MODERATOR
  ADMIN
}

enum Theme {
  LIGHT
  DARK
  AUTO
}

enum ContactType {
  EMAIL
  SMS
  PUSH
}

enum ReportType {
  CRIME
  HARASSMENT
  ROBBERY
  TRANSPORT
  FIRE
  FLOOD
  WEATHER
  OTHER
}

enum ReportStatus {
  PENDING
  VALIDATED
  FLAGGED
  REJECTED
}

enum VoteType {
  CONFIRM
  DISPUTE
}

enum SOSState {
  ACTIVE
  ENDED
  CANCELLED
}

enum PaymentProvider {
  STRIPE
}

enum PaymentStatus {
  PENDING
  ACTIVE
  CANCELLED
  FAILED
}

enum Plan {
  PREMIUM_MONTHLY
  PREMIUM_YEARLY
}

// Models
model User {
  id               String    @id @default(uuid())
  email            String    @unique
  passwordHash     String?
  firstName        String
  lastName         String
  phone            String?   // encrypted at rest
  phoneSearchHash  String?   @unique // sha256(normalized)
  role             Role      @default(USER)
  isActive         Boolean   @default(true)
  isBanned         Boolean   @default(false)
  isPremium        Boolean   @default(false)
  premiumUntil     DateTime?
  emailVerified    Boolean   @default(false)
  phoneVerified    Boolean   @default(false)
  twoFAEnabled     Boolean   @default(false)
  twoFASecret      String?   // encrypted at rest
  twoFABackupCodes String[]  @default([]) // hashed values
  locale           String?   @default("fr-FR")
  timezone         String?   @default("Europe/Paris")
  lastLoginAt      DateTime?
  lastLoginIP      String?
  loginCount       Int       @default(0)
  gdprConsent      Json?

  // Relations
  preferences      UserPreferences?
  contacts         UserContact[]
  reports          Report[]
  sosSessions      SOSSession[]
  payments         Payment[]

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
}

model UserPreferences {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  alertRadiusM    Int      @default(2000)
  categories      Json?
  theme           Theme    @default(LIGHT)
  sosMessage      String?
  pushEnabled     Boolean  @default(true)
  emailEnabled    Boolean  @default(true)
  smsEnabled      Boolean  @default(false)
  locationSharing Boolean  @default(false)
  profileVisible  Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model UserContact {
  id           String      @id @default(uuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  type         ContactType
  value        String      // encrypted at rest
  valueHash    String?     // sha256(normalized), for dedup/search
  label        String
  relationship String?
  priority     Int         @default(1)
  verified     Boolean     @default(false)
  isActive     Boolean     @default(true)

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([userId, type, valueHash])
}

model Report {
  id           String       @id @default(uuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  type         ReportType
  title        String
  description  String
  latitude     Float
  longitude    Float
  address      String?
  geom         Unsupported("geometry")?
  mediaUrls    String[]
  trustScore   Int          @default(50)
  status       ReportStatus @default(PENDING)
  voteCount    Int          @default(0)
  viewCount    Int          @default(0)
  aiModeration Json?

  votes        ReportVote[]

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  @@index([type, status])
  @@index([createdAt])
}

model ReportVote {
  reportId String
  voterId  String
  report   Report @relation(fields: [reportId], references: [id])
  voter    User   @relation(fields: [voterId], references: [id])
  vote     VoteType
  comment  String?
  createdAt DateTime @default(now())

  @@id([reportId, voterId])
  @@map("report_votes")
}

model SOSSession {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  state            SOSState @default(ACTIVE)
  message          String?
  startLocation    Unsupported("geometry")?
  lastLocation     Unsupported("geometry")?
  locationHistory  Json
  contactsNotified String[]
  startedAt        DateTime @default(now())
  endedAt          DateTime?
  lastHeartbeat    DateTime?
  createdAt        DateTime @default(now())

  @@index([userId, state])
}

model Payment {
  id           String          @id @default(uuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id])
  provider     PaymentProvider @default(STRIPE)
  plan         Plan
  externalId   String?
  customerId   String?
  amount       Decimal         @db.Decimal(10, 2)
  currency     String          @default("EUR")
  status       PaymentStatus   @default(PENDING)
  startedAt    DateTime?
  renewsAt     DateTime?
  cancelledAt  DateTime?
  metadata     Json?
  createdAt    DateTime        @default(now())

  @@index([userId, status])
}